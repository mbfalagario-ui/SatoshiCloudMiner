# Apple private keys never go into the image — use `fly secrets set` instead.
# NOTE: .env IS included in the build context (required by Emergent
# deployments). On Fly this is harmless: runtime secrets are injected via
# `fly secrets` and load_dotenv() does not override existing env vars.
keys/
*.p8

# Dev artefacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/
env/
node_modules/

# Tests (we don't run tests inside the prod image)
tests/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.log

# Docs that don't belong in a runtime image
README.md
*.md
