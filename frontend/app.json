  "expo": {
    "name": "Hashrate Cloud Miner",
    "slug": "satoshi-cloud-miner",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hashratecloudminer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Hashrate Cloud Miner — Non-custodial Bitcoin yield-tracking dashboard. Track indicative earnings, boost virtual hashpower, and withdraw to your own Lightning Network address. No on-device mining.",
