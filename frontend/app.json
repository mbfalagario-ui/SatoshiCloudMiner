{
  "expo": {
    "name": "Hashrate Cloud Miner",
    "slug": "satoshi-cloud-miner",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hashratecloudminer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Hashrate Cloud Miner — Bitcoin cloud-mining performance dashboard with AI yield agents and Lightning payouts.",
    "primaryColor": "#00FFA3",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.satoshicloudminer",
      "buildNumber": "21",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0E14"
      },
      "package": "app.satoshicloudminer",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B0E14"
        }
      ],
      "react-native-iap",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4ff5994e-ea94-4a01-9b49-ac548dfbbde1"
      }
    },
    "owner": "pastrypuffz"
  }
}
