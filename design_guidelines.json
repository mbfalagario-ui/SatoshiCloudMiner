      "borderRadius": "9999px",
      "padding": "4px 12px"
    }
  },
  "screens": {
    "HomeDashboard": {
      "layout": "Vertical stack with generous spacing (24px gap)",
      "key_elements": [
        "Total Balance (Monospace, Huge)",
        "Live Hash Rate counter (Neon Green, Pulsing)",
